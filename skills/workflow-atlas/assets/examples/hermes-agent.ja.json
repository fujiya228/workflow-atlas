  "flows": [
    {
      "id": "cli-start",
      "icon": "🚀",
      "name": "1. CLI 起動 → 対話エージェント",
      "sub": "hermes コマンドから AIAgent 構築まで",
      "description": "`hermes`（サブコマンド無し）が hermes_cli.main → cmd_chat を経て cli.py の REPL を起動し、AIAgent を構築してターンを駆動する。",
      "steps": [
        {
          "from": "user",
          "to": "cli",
          "passes": "hermes 起動 (argv: model/provider/toolsets/resume)",
          "note": "hermes_cli.main:main() がパース、サブコマンド無しは chat 既定 (main.py:12625)"
        },
        {
          "from": "cli",
          "to": "agent-loop",
          "passes": "AIAgent(model, provider, toolsets, session_id) + chat(query)",
          "note": "cmd_chat→cli.main(**kwargs)→AIAgent 構築し REPL 駆動 (main.py:2311, cli.py:821)"
        },
        {
          "from": "agent-loop",
          "to": "session-db",
          "passes": "session_id, source",
          "note": "起動時にセッション作成/復元 (SessionDB.create_session, hermes_state.py:1369)"
        },
        {
          "from": "agent-loop",
          "to": "user",
          "passes": "応答テキスト",
          "note": "REPL がターンを回し表示 (cli.chat, cli.py:14861)"
        }
      ]
    },
    {
      "id": "agent-turn",
      "icon": "🔄",
      "name": "2. エージェント1ターン (LLM 呼出)",
      "sub": "プロンプト組立 → 推論 → 永続化",
      "description": "ユーザーメッセージが run_conversation に入り、3層システムプロンプト（メモリ/スキル注入）を組み立て、provider へ推論要求、最終応答を確定して SessionDB に永続化する中核ターン。",
      "steps": [
        {
          "from": "user",
          "to": "agent-loop",
          "passes": "ユーザーメッセージ",
          "note": "run_conversation(user_message) (run_agent.py:5272 → conversation_loop.py:469)"
        },
        {
          "from": "agent-loop",
          "to": "system-prompt",
          "passes": "valid_tool_names, system_message",
          "note": "build_turn_context→build_system_prompt_parts; 安定/コンテキスト/揮発の3層 (turn_context.py:64, system_prompt.py:113)"
        },
        {
          "from": "memory-store",
          "to": "system-prompt",
          "passes": "MEMORY.md + USER.md スナップショット",
          "note": "揮発層に注入 (format_for_system_prompt, system_prompt.py:425)"
        },
        {
          "from": "skills-store",
          "to": "system-prompt",
          "passes": "スキル index (name+description)",
          "note": "build_skills_system_prompt (prompt_builder.py:1244)"
        },
        {
          "from": "system-prompt",
          "to": "agent-loop",
          "passes": "active_system_prompt",
          "note": "_cached_system_prompt にキャッシュ (turn_context.py:253)"
        },
        {
          "from": "agent-loop",
          "to": "model-client",
          "passes": "api_messages (system+履歴) + tool schemas + max_tokens",
          "note": "build_api_kwargs→interruptible_streaming_api_call (chat_completion_helpers.py:555,1567)"
        },
        {
          "from": "model-client",
          "to": "llm-provider",
          "passes": "chat.completions.create(stream=True)",
          "note": "api_mode で OpenAI互換/Anthropic/Bedrock/Codex 分岐 (chat_completion_helpers.py:1831)"
        },
        {
          "from": "llm-provider",
          "to": "model-client",
          "passes": "SSE deltas (text/reasoning/tool)",
          "note": "validate→normalize_response で統一 assistant_message"
        },
        {
          "from": "model-client",
          "to": "agent-loop",
          "passes": "assistant_message (.content/.tool_calls/.finish_reason)",
          "note": "tool_calls 無→最終応答確定 (conversation_loop.py:3529,4381)"
        },
        {
          "from": "agent-loop",
          "to": "session-db",
          "passes": "messages[] (role/content/tool_calls)",
          "note": "_persist_session→append_message (run_agent.py:1512,1581)"
        },
        {
          "from": "agent-loop",
          "to": "user",
          "passes": "最終テキスト (deltas 逐次配信)",
          "note": "stream_delta_callback (run_agent.py:4213)"
        }
      ]
    },
    {
      "id": "tool-roundtrip",
      "icon": "🛠️",
      "name": "3. ツール呼び出しラウンドトリップ",
      "sub": "tool_calls → 実行 → 再注入ループ",
      "description": "モデルが tool_calls を返すと tool_executor が registry.dispatch で実行し、tool 結果メッセージを messages に追加して再びループへ。",
      "steps": [
        {
          "from": "llm-provider",
          "to": "agent-loop",
          "passes": "assistant_message.tool_calls [{id, name, arguments(json)}]",
          "note": "tool_calls 検出→ツール分岐 (conversation_loop.py:3718)"
        },
        {
          "from": "agent-loop",
          "to": "tool-exec",
          "passes": "assistant_message, messages, task_id",
          "note": "_execute_tool_calls→execute_tool_calls_concurrent/sequential (run_agent.py:5170)"
        },
        {
          "from": "tool-exec",
          "to": "agent-loop",
          "passes": "tool 結果 {role:tool, name, content, tool_call_id}",
          "note": "registry.dispatch→make_tool_result_message; messages に追加 (model_tools.py:1115, tool_dispatch_helpers.py:320)"
        },
        {
          "from": "agent-loop",
          "to": "model-client",
          "passes": "tool 結果込み api_messages",
          "note": "ループ継続、次の LLM 呼出 (conversation_loop.py:4069)"
        },
        {
          "from": "model-client",
          "to": "llm-provider",
          "passes": "更新 messages + tools",
          "note": "次イテレーション推論"
        }
      ]
    },
    {
      "id": "terminal-backend",
      "icon": "💻",
      "name": "4. ターミナル実行バックエンド",
      "sub": "terminal ツール → 6 バックエンド分岐",
      "description": "terminal ツールが TERMINAL_ENV から実行環境を選び、local/Docker/SSH/Modal/Daytona/Singularity のいずれかでコマンドを走らせ結果を回収する。",
      "steps": [
        {
          "from": "agent-loop",
          "to": "tool-exec",
          "passes": "ToolCall(terminal, {command, cwd})",
          "note": "registry.dispatch('terminal') (model_tools.py:876)"
        },
        {
          "from": "tool-exec",
          "to": "terminal-tool",
          "passes": "command, env_type=TERMINAL_ENV",
          "note": "terminal_tool→_create_environment ファクトリ (terminal_tool.py:1843,1225)"
        },
        {
          "from": "terminal-tool",
          "to": "exec-backend",
          "passes": "bash -c '<snapshot>; <cmd>'",
          "note": "local=Popen / docker=docker exec / ssh・modal・daytona は遠隔 (base.py:327)"
        },
        {
          "from": "exec-backend",
          "to": "terminal-tool",
          "passes": "{output, returncode}",
          "note": "実行結果を回収 (base.py:872)"
        },
        {
          "from": "terminal-tool",
          "to": "tool-exec",
          "passes": "{output, exit_code, status} JSON",
          "note": "結果を整形 (terminal_tool.py:1890)"
        },
        {
          "from": "tool-exec",
          "to": "agent-loop",
          "passes": "tool 結果メッセージ",
          "note": "messages に追加しループ継続"
        }
      ]
    },
    {
      "id": "execute-code-rpc",
      "icon": "⚡",
      "name": "5. execute_code RPC",
      "sub": "生成スクリプトがツールを RPC 呼出",
      "description": "execute_code が子プロセスに hermes_tools スタブを生成し、ソケット経由の RPC で複数ツールを 1 ターン内に連鎖実行（ゼロコンテキストコスト）。",
      "steps": [
        {
          "from": "agent-loop",
          "to": "tool-exec",
          "passes": "ToolCall(execute_code, {code})",
          "note": "sandbox_enabled = enabled_tools (model_tools.py:1110)"
        },
        {
          "from": "tool-exec",
          "to": "code-exec",
          "passes": "生成 hermes_tools.py (_call スタブ) + 子プロセス起動",
          "note": "generate_hermes_tools_module; HERMES_RPC_SOCKET (UDS/loopback) (code_execution_tool.py:259,1198)"
        },
        {
          "from": "code-exec",
          "to": "tool-exec",
          "passes": "{'tool':name,'args':{...}} (RPC over socket)",
          "note": "子 _call()→_rpc_server_loop が allowlist 検証→handle_function_call (code_execution_tool.py:525)"
        },
        {
          "from": "tool-exec",
          "to": "code-exec",
          "passes": "ツール結果 JSON",
          "note": "ソケットで子へ返却。全パイプラインが 1 ターンで完結 (code_execution_tool.py:582)"
        },
        {
          "from": "code-exec",
          "to": "agent-loop",
          "passes": "スクリプト stdout / 最終結果",
          "note": "execute_code 結果をツール結果として返す"
        }
      ]
    },
    {
      "id": "mcp-integration",
      "icon": "🔌",
      "name": "6. 外部 MCP 連携",
      "sub": "接続 → ツール発見 → 登録 → 呼出",
      "description": "外部 MCP サーバへ接続し list_tools で発見、mcp_<srv>_<tool> として registry に登録、モデル呼出時に call_tool で実行。",
      "steps": [
        {
          "from": "cli",
          "to": "mcp-client",
          "passes": "mcp_servers config (command/url, transport, tools)",
          "note": "セッション開始時 register_mcp_servers (mcp_tool.py:4019)"
        },
        {
          "from": "mcp-client",
          "to": "mcp-server",
          "passes": "stdio/HTTP/SSE 接続 + initialize()",
          "note": "専用 mcp-event-loop スレッド (mcp_tool.py:191)"
        },
        {
          "from": "mcp-server",
          "to": "mcp-client",
          "passes": "list_tools() → [Tool(name, inputSchema)]",
          "note": "ツール発見 (mcp_tool.py:2137)"
        },
        {
          "from": "mcp-client",
          "to": "tool-exec",
          "passes": "registry.register('mcp_<srv>_<tool>', schema, handler)",
          "note": "接頭辞付きでレジストリ登録 (mcp_tool.py:3933)"
        },
        {
          "from": "agent-loop",
          "to": "tool-exec",
          "passes": "ToolCall(mcp_<srv>_<tool>, args)",
          "note": "モデルが MCP ツール呼出 (registry.dispatch)"
        },
        {
          "from": "tool-exec",
          "to": "mcp-client",
          "passes": "call_tool(name, arguments)",
          "note": "_make_tool_handler; circuit breaker (mcp_tool.py:3110)"
        },
        {
          "from": "mcp-client",
          "to": "mcp-server",
          "passes": "session.call_tool(...)",
          "note": "MCP ループ上で実行 (mcp_tool.py:3152)"
        },
        {
          "from": "mcp-server",
          "to": "mcp-client",
          "passes": "結果 content (text/image)",
          "note": "結果回収 (mcp_tool.py:3160)"
        },
        {
          "from": "mcp-client",
          "to": "agent-loop",
          "passes": "結果メッセージ",
          "note": "<untrusted_tool_result> でラップ→messages"
        }
      ]
    },
    {
      "id": "delegate",
      "icon": "👥",
      "name": "7. サブエージェント委譲",
      "sub": "delegate_task → 子 AIAgent → 要約回収",
      "description": "delegate_task が制限ツールセットの子 AIAgent を構築し別スレッドで run_conversation、親は要約のみを受け取る。",
      "steps": [
        {
          "from": "agent-loop",
          "to": "tool-exec",
          "passes": "ToolCall(delegate_task, {goal, context, toolsets, role})",
          "note": "registry.dispatch('delegate_task') (delegate_tool.py:2065)"
        },
        {
          "from": "tool-exec",
          "to": "delegate",
          "passes": "goal, toolsets, parent_agent",
          "note": "深さ/並列数チェック→_build_child_agent (delegate_tool.py:972)"
        },
        {
          "from": "delegate",
          "to": "agent-loop",
          "passes": "child = AIAgent(制限 toolset, depth+1); run_conversation(goal)",
          "note": "子を別スレッドで実行 (delegate_tool.py:1651)"
        },
        {
          "from": "agent-loop",
          "to": "delegate",
          "passes": "child 結果 {status, summary=final_response}",
          "note": "親は要約のみ参照 (delegate_tool.py:2341)"
        },
        {
          "from": "delegate",
          "to": "tool-exec",
          "passes": "JSON {results:[...]}",
          "note": "delegate_task 結果"
        },
        {
          "from": "tool-exec",
          "to": "agent-loop",
          "passes": "結果メッセージ",
          "note": "親 messages に追加"
        }
      ]
    },
    {
      "id": "compression",
      "icon": "🗜️",
      "name": "8. コンテキスト圧縮",
      "sub": "補助モデルで要約 → セッション交替",
      "description": "should_compress が立つと ContextCompressor が補助サマライザモデルで履歴を要約し、新しい子セッションへローテーションする。",
      "steps": [
        {
          "from": "agent-loop",
          "to": "model-client",
          "passes": "要約対象 messages, current_tokens",
          "note": "should_compress→compress_context→ContextCompressor.compress (conversation_loop.py:4053)"
        },
        {
          "from": "model-client",
          "to": "llm-provider",
          "passes": "要約プロンプト",
          "note": "補助サマライザ(安価)モデルへ (auxiliary_client.call_llm)"
        },
        {
          "from": "llm-provider",
          "to": "model-client",
          "passes": "要約テキスト",
          "note": "失敗時メインモデルにフォールバック"
        },
        {
          "from": "model-client",
          "to": "agent-loop",
          "passes": "(compressed_messages, new_system_prompt)",
          "note": "圧縮結果 (context_compressor.py:2151)"
        },
        {
          "from": "agent-loop",
          "to": "session-db",
          "passes": "圧縮 messages, 新 child session_id",
          "note": "session ローテーション + 圧縮ロック (conversation_compression.py:361,460)"
        }
      ]
    },
    {
      "id": "gateway-msg",
