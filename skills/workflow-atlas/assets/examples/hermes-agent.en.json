  "flows": [
    {
      "id": "cli-start",
      "icon": "🚀",
      "name": "1. CLI launch → interactive agent",
      "sub": "From hermes command to AIAgent construction",
      "description": "`hermes` (no subcommand) goes through hermes_cli.main → cmd_chat to launch the cli.py REPL, constructs an AIAgent, and drives turns.",
      "steps": [
        {
          "from": "user",
          "to": "cli",
          "passes": "hermes launch (argv: model/provider/toolsets/resume)",
          "note": "hermes_cli.main:main() parses; no subcommand defaults to chat (main.py:12625)"
        },
        {
          "from": "cli",
          "to": "agent-loop",
          "passes": "AIAgent(model, provider, toolsets, session_id) + chat(query)",
          "note": "cmd_chat→cli.main(**kwargs)→constructs AIAgent and drives REPL (main.py:2311, cli.py:821)"
        },
        {
          "from": "agent-loop",
          "to": "session-db",
          "passes": "session_id, source",
          "note": "Create/restore session on launch (SessionDB.create_session, hermes_state.py:1369)"
        },
        {
          "from": "agent-loop",
          "to": "user",
          "passes": "response text",
          "note": "REPL cycles turns and renders (cli.chat, cli.py:14861)"
        }
      ]
    },
    {
      "id": "agent-turn",
      "icon": "🔄",
      "name": "2. Agent turn (LLM call)",
      "sub": "Prompt assembly → inference → persistence",
      "description": "A user message enters run_conversation, the 3-layer system prompt (memory/skill injection) is assembled, an inference request is sent to the provider, and the final response is finalized and persisted to the SessionDB. This is the core turn.",
      "steps": [
        {
          "from": "user",
          "to": "agent-loop",
          "passes": "user message",
          "note": "run_conversation(user_message) (run_agent.py:5272 → conversation_loop.py:469)"
        },
        {
          "from": "agent-loop",
          "to": "system-prompt",
          "passes": "valid_tool_names, system_message",
          "note": "build_turn_context→build_system_prompt_parts; 3 layers: stable/context/volatile (turn_context.py:64, system_prompt.py:113)"
        },
        {
          "from": "memory-store",
          "to": "system-prompt",
          "passes": "MEMORY.md + USER.md snapshot",
          "note": "Injected into the volatile layer (format_for_system_prompt, system_prompt.py:425)"
        },
        {
          "from": "skills-store",
          "to": "system-prompt",
          "passes": "skill index (name+description)",
          "note": "build_skills_system_prompt (prompt_builder.py:1244)"
        },
        {
          "from": "system-prompt",
          "to": "agent-loop",
          "passes": "active_system_prompt",
          "note": "Cached in _cached_system_prompt (turn_context.py:253)"
        },
        {
          "from": "agent-loop",
          "to": "model-client",
          "passes": "api_messages (system+history) + tool schemas + max_tokens",
          "note": "build_api_kwargs→interruptible_streaming_api_call (chat_completion_helpers.py:555,1567)"
        },
        {
          "from": "model-client",
          "to": "llm-provider",
          "passes": "chat.completions.create(stream=True)",
          "note": "api_mode branches across OpenAI-compatible/Anthropic/Bedrock/Codex (chat_completion_helpers.py:1831)"
        },
        {
          "from": "llm-provider",
          "to": "model-client",
          "passes": "SSE deltas (text/reasoning/tool)",
          "note": "validate→normalize_response unifies into assistant_message"
        },
        {
          "from": "model-client",
          "to": "agent-loop",
          "passes": "assistant_message (.content/.tool_calls/.finish_reason)",
          "note": "No tool_calls→finalize response (conversation_loop.py:3529,4381)"
        },
        {
          "from": "agent-loop",
          "to": "session-db",
          "passes": "messages[] (role/content/tool_calls)",
          "note": "_persist_session→append_message (run_agent.py:1512,1581)"
        },
        {
          "from": "agent-loop",
          "to": "user",
          "passes": "final text (deltas streamed incrementally)",
          "note": "stream_delta_callback (run_agent.py:4213)"
        }
      ]
    },
    {
      "id": "tool-roundtrip",
      "icon": "🛠️",
      "name": "3. Tool call round-trip",
      "sub": "tool_calls → execute → re-inject loop",
      "description": "When the model returns tool_calls, the tool_executor runs them via registry.dispatch, appends tool result messages to messages, and loops again.",
      "steps": [
        {
          "from": "llm-provider",
          "to": "agent-loop",
          "passes": "assistant_message.tool_calls [{id, name, arguments(json)}]",
          "note": "Detect tool_calls→branch to tools (conversation_loop.py:3718)"
        },
        {
          "from": "agent-loop",
          "to": "tool-exec",
          "passes": "assistant_message, messages, task_id",
          "note": "_execute_tool_calls→execute_tool_calls_concurrent/sequential (run_agent.py:5170)"
        },
        {
          "from": "tool-exec",
          "to": "agent-loop",
          "passes": "tool result {role:tool, name, content, tool_call_id}",
          "note": "registry.dispatch→make_tool_result_message; appended to messages (model_tools.py:1115, tool_dispatch_helpers.py:320)"
        },
        {
          "from": "agent-loop",
          "to": "model-client",
          "passes": "api_messages including tool results",
          "note": "Continue loop, next LLM call (conversation_loop.py:4069)"
        },
        {
          "from": "model-client",
          "to": "llm-provider",
          "passes": "updated messages + tools",
          "note": "Next iteration inference"
        }
      ]
    },
    {
      "id": "terminal-backend",
      "icon": "💻",
      "name": "4. Terminal execution backend",
      "sub": "terminal tool → 6 backend branches",
      "description": "The terminal tool selects the execution environment from TERMINAL_ENV and runs the command on one of local/Docker/SSH/Modal/Daytona/Singularity, then collects the result.",
      "steps": [
        {
          "from": "agent-loop",
          "to": "tool-exec",
          "passes": "ToolCall(terminal, {command, cwd})",
          "note": "registry.dispatch('terminal') (model_tools.py:876)"
        },
        {
          "from": "tool-exec",
          "to": "terminal-tool",
          "passes": "command, env_type=TERMINAL_ENV",
          "note": "terminal_tool→_create_environment factory (terminal_tool.py:1843,1225)"
        },
        {
          "from": "terminal-tool",
          "to": "exec-backend",
          "passes": "bash -c '<snapshot>; <cmd>'",
          "note": "local=Popen / docker=docker exec / ssh, modal, daytona are remote (base.py:327)"
        },
        {
          "from": "exec-backend",
          "to": "terminal-tool",
          "passes": "{output, returncode}",
          "note": "Collect execution result (base.py:872)"
        },
        {
          "from": "terminal-tool",
          "to": "tool-exec",
          "passes": "{output, exit_code, status} JSON",
          "note": "Format result (terminal_tool.py:1890)"
        },
        {
          "from": "tool-exec",
          "to": "agent-loop",
          "passes": "tool result message",
          "note": "Append to messages and continue loop"
        }
      ]
    },
    {
      "id": "execute-code-rpc",
      "icon": "⚡",
      "name": "5. execute_code RPC",
      "sub": "Generated script calls tools via RPC",
      "description": "execute_code generates a hermes_tools stub in a child process and chains multiple tools within a single turn via socket-based RPC (zero context cost).",
      "steps": [
        {
          "from": "agent-loop",
          "to": "tool-exec",
          "passes": "ToolCall(execute_code, {code})",
          "note": "sandbox_enabled = enabled_tools (model_tools.py:1110)"
        },
        {
          "from": "tool-exec",
          "to": "code-exec",
          "passes": "Generated hermes_tools.py (_call stub) + child process launch",
          "note": "generate_hermes_tools_module; HERMES_RPC_SOCKET (UDS/loopback) (code_execution_tool.py:259,1198)"
        },
        {
          "from": "code-exec",
          "to": "tool-exec",
          "passes": "{'tool':name,'args':{...}} (RPC over socket)",
          "note": "child _call()→_rpc_server_loop validates allowlist→handle_function_call (code_execution_tool.py:525)"
        },
        {
          "from": "tool-exec",
          "to": "code-exec",
          "passes": "tool result JSON",
          "note": "Returned to child over socket. Entire pipeline completes in 1 turn (code_execution_tool.py:582)"
        },
        {
          "from": "code-exec",
          "to": "agent-loop",
          "passes": "script stdout / final result",
          "note": "Returns execute_code output as the tool result"
        }
      ]
    },
    {
      "id": "mcp-integration",
      "icon": "🔌",
      "name": "6. External MCP integration",
      "sub": "connect → discover tools → register → call",
      "description": "Connects to an external MCP server, discovers tools via list_tools, registers them in the registry as mcp_<srv>_<tool>, and executes them via call_tool during model calls.",
      "steps": [
        {
          "from": "cli",
          "to": "mcp-client",
          "passes": "mcp_servers config (command/url, transport, tools)",
          "note": "register_mcp_servers at session start (mcp_tool.py:4019)"
        },
        {
          "from": "mcp-client",
          "to": "mcp-server",
          "passes": "stdio/HTTP/SSE connection + initialize()",
          "note": "Dedicated mcp-event-loop thread (mcp_tool.py:191)"
        },
        {
          "from": "mcp-server",
          "to": "mcp-client",
          "passes": "list_tools() → [Tool(name, inputSchema)]",
          "note": "Tool discovery (mcp_tool.py:2137)"
        },
        {
          "from": "mcp-client",
          "to": "tool-exec",
          "passes": "registry.register('mcp_<srv>_<tool>', schema, handler)",
          "note": "Registered in the registry with a prefix (mcp_tool.py:3933)"
        },
        {
          "from": "agent-loop",
          "to": "tool-exec",
          "passes": "ToolCall(mcp_<srv>_<tool>, args)",
          "note": "Model calls the MCP tool (registry.dispatch)"
        },
        {
          "from": "tool-exec",
          "to": "mcp-client",
          "passes": "call_tool(name, arguments)",
          "note": "_make_tool_handler; circuit breaker (mcp_tool.py:3110)"
        },
        {
          "from": "mcp-client",
          "to": "mcp-server",
          "passes": "session.call_tool(...)",
          "note": "Executed on the MCP loop (mcp_tool.py:3152)"
        },
        {
          "from": "mcp-server",
          "to": "mcp-client",
          "passes": "result content (text/image)",
          "note": "Collect result (mcp_tool.py:3160)"
        },
        {
          "from": "mcp-client",
          "to": "agent-loop",
          "passes": "result message",
          "note": "Wrapped in <untrusted_tool_result>→messages"
        }
      ]
    },
    {
      "id": "delegate",
      "icon": "👥",
      "name": "7. Sub-agent delegation",
      "sub": "delegate_task → child AIAgent → collect summary",
      "description": "delegate_task constructs a child AIAgent with a restricted toolset, runs run_conversation on a separate thread, and the parent receives only the summary.",
      "steps": [
        {
          "from": "agent-loop",
          "to": "tool-exec",
          "passes": "ToolCall(delegate_task, {goal, context, toolsets, role})",
          "note": "registry.dispatch('delegate_task') (delegate_tool.py:2065)"
        },
        {
          "from": "tool-exec",
          "to": "delegate",
          "passes": "goal, toolsets, parent_agent",
          "note": "Check depth/concurrency→_build_child_agent (delegate_tool.py:972)"
        },
        {
          "from": "delegate",
          "to": "agent-loop",
          "passes": "child = AIAgent(restricted toolset, depth+1); run_conversation(goal)",
          "note": "Run the child on a separate thread (delegate_tool.py:1651)"
        },
        {
          "from": "agent-loop",
          "to": "delegate",
          "passes": "child result {status, summary=final_response}",
          "note": "Parent references only the summary (delegate_tool.py:2341)"
        },
        {
          "from": "delegate",
          "to": "tool-exec",
          "passes": "JSON {results:[...]}",
          "note": "delegate_task result"
        },
        {
          "from": "tool-exec",
          "to": "agent-loop",
          "passes": "result message",
          "note": "Appended to parent messages"
        }
      ]
    },
    {
      "id": "compression",
      "icon": "🗜️",
      "name": "8. Context compression",
      "sub": "summarize with auxiliary model → session rotation",
      "description": "When should_compress fires, the ContextCompressor summarizes the history with an auxiliary summarizer model and rotates to a new child session.",
      "steps": [
        {
          "from": "agent-loop",
          "to": "model-client",
          "passes": "messages to summarize, current_tokens",
          "note": "should_compress→compress_context→ContextCompressor.compress (conversation_loop.py:4053)"
        },
        {
          "from": "model-client",
          "to": "llm-provider",
          "passes": "summarization prompt",
          "note": "To the auxiliary summarizer (cheap) model (auxiliary_client.call_llm)"
        },
        {
          "from": "llm-provider",
          "to": "model-client",
          "passes": "summary text",
          "note": "Falls back to the main model on failure"
        },
        {
          "from": "model-client",
          "to": "agent-loop",
          "passes": "(compressed_messages, new_system_prompt)",
          "note": "Compression result (context_compressor.py:2151)"
        },
        {
          "from": "agent-loop",
          "to": "session-db",
          "passes": "compressed messages, new child session_id",
          "note": "Session rotation + compression lock (conversation_compression.py:361,460)"
        }
      ]
    },
    {
      "id": "gateway-msg",
      "icon": "💬",
      "name": "9. Messaging Gateway receive→reply",
      "sub": "Round-trip for Telegram/Slack etc.",
      "description": "The adapter normalizes a platform message into a MessageEvent, routes to an AIAgent by session_key, and returns the response via streamed edits.",
      "steps": [
        {
          "from": "user",
          "to": "msg-platform",
          "passes": "send message",
          "note": "Posted to Telegram/Slack etc."
        },
        {
          "from": "msg-platform",
          "to": "gateway",
          "passes": "Update/Event {chat_id, text, user_id, thread}",
          "note": "adapter normalizes into MessageEvent (telegram.py:6649)"
        },
        {
          "from": "gateway",
          "to": "session-db",
          "passes": "build_session_key 'agent:main:telegram:dm:{chat_id}'",
          "note": "Route history by session key (session.py:646)"
        },
        {
          "from": "gateway",
          "to": "agent-loop",
          "passes": "user_message, conversation_history, task_id=session_id",
          "note": "_run_agent_inner→run_conversation; AIAgent is cached (run.py:15848)"
        },
        {
          "from": "agent-loop",
          "to": "model-client",
          "passes": "api_messages + tools",
          "note": "Inference turn (shared with Flow 2)"
        },
        {
          "from": "agent-loop",
          "to": "gateway",
          "passes": "text deltas",
          "note": "stream_delta_callback→GatewayStreamConsumer.on_delta (run.py:15374)"
        },
        {
          "from": "gateway",
          "to": "msg-platform",
          "passes": "response text (incremental edits)",
          "note": "adapter.send→edit_message (editMessageText) (stream_consumer.py:795)"
        },
        {
          "from": "msg-platform",
          "to": "user",
          "passes": "render reply",
          "note": "Delivered to the platform"
        }
      ]
    },
    {
      "id": "voice",
      "icon": "🎙️",
      "name": "10. Voice memo → transcription",
      "sub": "voice DL → transcribe → agent",
      "description": "Downloads and caches the voice memo, transcribes it with transcribe_audio (faster-whisper/cloud Whisper), then injects it as a user message.",
      "steps": [
        {
          "from": "user",
          "to": "msg-platform",
          "passes": "send voice memo",
          "note": "Audio attachment"
        },
        {
          "from": "msg-platform",
          "to": "gateway",
          "passes": "audio file (audio/ogg)",
          "note": "DL→cache, _enrich_message_with_transcription (run.py:12702)"
        },
        {
          "from": "gateway",
