#!/usr/bin/env bash
#
# pre-push — require a plugin version bump when shipped plugin files change.
#
# Rationale: the marketplace only treats a release as "new" when
# .claude-plugin/plugin.json's "version" changes (an explicit version field is
# set, so commits are NOT auto-versioned by SHA). This guard makes it
# impossible to publish skill changes to main without moving the version, while
# leaving the *size* of the bump (patch / minor / major) to your judgment.
#
# Scope: only gates pushes to main. WIP feature branches push freely.
# Override (rare): git push --no-verify
#
set -euo pipefail

PLUGIN_JSON=".claude-plugin/plugin.json"
WATCH="skills/"                  # shipped payload; a change here requires a bump
PROTECTED_REF="refs/heads/main"  # only enforce when publishing main
ZERO="0000000000000000000000000000000000000000"
EMPTY_TREE="$(git hash-object -t tree /dev/null)"

version_at() {                   # $1 = ref/sha → prints plugin version (or empty)
  git show "$1:$PLUGIN_JSON" 2>/dev/null \
    | sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1 || true
}

block=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue          # branch deletion → nothing to check
  [ "$remote_ref" = "$PROTECTED_REF" ] || continue # only gate main

  if [ "$remote_sha" = "$ZERO" ]; then
    base="$EMPTY_TREE"                            # new ref → diff against empty tree
  else
    base="$remote_sha"
  fi

  if git diff --name-only "$base" "$local_sha" -- "$WATCH" | grep -q .; then
    old_ver="$(version_at "$base")"
    new_ver="$(version_at "$local_sha")"
    if [ "$old_ver" = "$new_ver" ]; then
      next_patch="x.y.(z+1)"
      case "$new_ver" in *.*.*) next_patch="${new_ver%.*}.$(( ${new_ver##*.} + 1 ))" ;; esac
      echo "" >&2
      echo "✗ pre-push blocked: '$WATCH' changed but $PLUGIN_JSON version is still \"$new_ver\"." >&2
      echo "  Bump it before publishing to main:" >&2
      echo "    patch (fixes):        $next_patch" >&2
      echo "    minor (new features): bump the middle number, reset patch to 0" >&2
      echo "  Then commit the bump and push again. (Emergency override: git push --no-verify)" >&2
      echo "" >&2
      block=1
    fi
  fi
done

exit "$block"
